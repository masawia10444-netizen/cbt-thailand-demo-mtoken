{
    "name": "next-cbt",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "env-cmd -f .env.local next dev",
        "dev:gdev": "env-cmd -f .env.gdev next dev",
        "dev:stag": "env-cmd -f .env.staging next dev",
        "build": "env-cmd -f .env.local next build",
        "build:gdev": "env-cmd -f .env.gdev next build",
        "build:staging": "env-cmd -f .env.staging next build && next start",
        "build:production": "env-cmd -f .env.production next build && next start -p 3001",
        "start": "env-cmd -f .env.local next start",
        "start:gdev": "env-cmd -f .env.gdev next start",
        "start:staging": "env-cmd -f .env.gdev next start",
        "start:production": "env-cmd -f .env.production next start -p 3001",
        "deploy": "next build && next export",
        "deploy:gdev": "env-cmd -f .env.gdev next build && next export",
        "pm2-build:staging": "env-cmd -f .env.staging next build && pm2 start ./node_modules/next/dist/bin/next",
        "pm2-start:staging": "env-cmd -f .env.staging pm2 start ./node_modules/next/dist/bin/next",
        "pm2-build:production": "env-cmd -f .env.production next build && pm2 start ./node_modules/next/dist/bin/next",
        "pm2-start:production": "env-cmd -f .env.production pm2 start ./node_modules/next/dist/bin/next"
    },
    "dependencies": {
        "@babel/plugin-proposal-decorators": "^7.10.5",
        "@date-io/date-fns": "^1.3.13",
        "@material-ui/core": "^4.11.0",
        "@material-ui/icons": "^4.9.1",
        "@material-ui/lab": "^4.0.0-alpha.56",
        "@material-ui/pickers": "^3.2.10",
        "@types/arcgis-js-api": "^4.16.0",
        "@types/jsonp": "^0.2.0",
        "@types/jsonwebtoken": "^8.5.0",
        "@types/react-beautiful-dnd": "^13.0.0",
        "@types/react-swipeable-views-utils": "^0.13.2",
        "@types/yup": "^0.29.7",
        "aos": "^2.3.4",
        "autosuggest-highlight": "^3.1.1",
        "clsx": "^1.1.1",
        "compression": "^1.7.4",
        "crypto-js": "^4.0.0",
        "date-fns": "^2.16.1",
        "env-cmd": "^10.1.0",
        "esri-loader": "^2.15.0",
        "formik": "^2.1.5",
        "i18next": "^19.8.3",
        "isomorphic-unfetch": "^3.0.0",
        "jsonp": "^0.2.1",
        "jsonwebtoken": "^8.5.1",
        "mobx": "^5.15.7",
        "mobx-react-lite": "^2.1.0",
        "moment": "^2.29.1",
        "next": "^10.0.0",
        "next-i18next": "^6.0.2",
        "nprogress": "^0.2.0",
        "nuka-carousel": "^4.7.1",
        "react": "^17.0.1",
        "react-awesome-slider": "^4.1.0",
        "react-beautiful-dnd": "^13.0.0",
        "react-custom-scrollbars": "^4.2.1",
        "react-dom": "^17.0.1",
        "react-facebook-login": "^4.1.1",
        "react-google-login": "^5.1.22",
        "react-i18next": "^11.7.3",
        "react-multi-carousel": "^2.5.5",
        "react-player": "^2.6.2",
        "react-swipeable-views": "^0.13.9",
        "semantic-ui-react": "^1.2.1",
        "styled-components": "^5.2.0",
        "use-resize-observer": "^6.1.0",
        "yup": "^0.29.3"
    },
    "devDependencies": {
        "@types/lodash": "^4.14.162",
        "@types/node": "^14.14.3",
        "@types/react": "^16.9.49",
        "@types/react-custom-scrollbars": "^4.0.7",
        "@types/react-facebook-login": "^4.1.2",
        "@types/react-swipeable-views": "^0.13.0",
        "babel-plugin-styled-components": "^1.11.1",
        "ts-loader": "^8.0.4",
        "typescript": "^4.0.3"
    }
}
